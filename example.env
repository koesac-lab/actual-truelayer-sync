# URL of your self-hosted Actual Budget instance (e.g. http://192.168.1.10:5006)
ACTUAL_SERVER_URL=

# Your Actual Budget login password
ACTUAL_SERVER_PASSWORD=

# The sync ID for the budget you want to import into.
# Found under: Settings → Show advanced settings → ID
ACTUAL_SYNC_ID=

# TrueLayer developer credentials — from https://console.truelayer.com/
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=

# Set to "sandbox" to use TrueLayer's sandbox environment with mock bank data.
# In sandbox mode the client_id is automatically prefixed with "sandbox-" if needed.
# The setup UI and sync container both respect this variable.
# TRUELAYER_ENV=sandbox

# How often to run the sync, in standard cron syntax.
# If not set, the sync runs once on startup and then exits.
# Example: every 4 hours
# CRON_SCHEDULE=0 */4 * * *

# Timezone for the cron schedule (uses IANA timezone names).
# If not set, UTC is used.
# TZ=Europe/London

# Set to "text" for human-readable logs instead of JSON (useful for local development).
# LOG_FORMAT=text

# Set to "true" to enable verbose Actual Budget API logging.
# DEBUG=true
